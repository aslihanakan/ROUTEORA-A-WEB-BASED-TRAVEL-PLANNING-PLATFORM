<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Routeora</title>
    <link rel="icon" type="image/jpeg" href="~/images/icons/website_icon.jpg" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --blue-1: #D6E8FF;
            --blue-2: #94B8E8;
            --blue-3: #4A7EC2;
            --blue-4: #1E4D8C;
            --blue-5: #0A1F4E;
            --aurora-teal: #00E5C8;
            --aurora-green: #4DFFA6;
            --aurora-cyan: #00C8E0;
            --card-bg: #EAF2FF;
            --card-border: #B8D4F5;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #f0f6ff;
            color: #1a2a4a;
            margin: 0;
        }

        /* ============ NAVBAR ============ */
        .routeora-nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: var(--blue-5);
            border-bottom: 1px solid rgba(0,200,224,0.15);
            padding: 0;
        }

        .nav-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 1.5rem;
            height: 64px;
            gap: 1rem;
        }

        /* Brand with aurora gradient text */
        .brand-logo {
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: -0.5px;
            background: linear-gradient(90deg, #fff 0%, #a8edea 30%, #00E5C8 55%, #4DFFA6 80%, #b0f5d0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            position: relative;
        }

        .brand-logo .brand-icon {
            background: linear-gradient(135deg, #00E5C8, #4DFFA6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 1.3rem;
        }

        /* Nav links */
        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.1rem;
            list-style: none;
            margin: 0;
            padding: 0;
            flex-wrap: nowrap;
            white-space: nowrap;
        }

        .nav-links a {
            color: rgba(200,225,255,0.8);
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 500;
            padding: 0.35rem 0.6rem;
            border-radius: 6px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            white-space: nowrap;
        }

        .nav-links a:hover {
            color: #fff;
            background: rgba(0,229,200,0.12);
        }

        .nav-links a i { font-size: 0.75rem; }

        /* Auth buttons */
        .nav-auth {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-nav-login {
            color: rgba(200,225,255,0.85);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.375rem 0.875rem;
            border-radius: 6px;
            border: 1px solid rgba(0,229,200,0.25);
            transition: all 0.2s;
        }

        .btn-nav-login:hover {
            color: #fff;
            border-color: rgba(0,229,200,0.6);
            background: rgba(0,229,200,0.08);
        }

        .btn-nav-register {
            background: linear-gradient(135deg, #00C8A0, #00A8B5);
            color: #fff;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.375rem 1rem;
            border-radius: 6px;
            border: none;
            transition: all 0.2s;
        }

        .btn-nav-register:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(0,200,160,0.4);
            color: #fff;
        }

        .nav-user-greeting {
            color: rgba(200,225,255,0.6);
            font-size: 0.8rem;
        }

        .btn-nav-logout {
            background: none;
            border: 1px solid rgba(200,225,255,0.2);
            color: rgba(200,225,255,0.7);
            font-size: 0.8rem;
            padding: 0.3rem 0.75rem;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-nav-logout:hover {
            border-color: #e57373;
            color: #ef9a9a;
        }

        /* Mobile toggle */
        .nav-toggle {
            display: none;
            background: none;
            border: 1px solid rgba(0,229,200,0.3);
            border-radius: 6px;
            padding: 0.4rem 0.6rem;
            color: #a8edea;
            cursor: pointer;
        }

        /* Desktop: always show nav links inline */
        .nav-collapsible {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
            justify-content: space-between;
        }

        @@media (max-width: 991px) {
            .nav-toggle { display: flex; align-items: center; }
            .nav-collapsible {
                display: none;
                position: absolute;
                top: 64px;
                left: 0; right: 0;
                background: var(--blue-5);
                border-bottom: 1px solid rgba(0,200,224,0.15);
                padding: 1rem 1.5rem;
                flex-direction: column;
                gap: 0.5rem;
            }
            .nav-collapsible.open { display: flex; }
            .nav-links { flex-direction: column; width: 100%; }
            .nav-links a { width: 100%; padding: 0.6rem 0.75rem; }
            .nav-auth { flex-direction: column; width: 100%; }
            .btn-nav-login, .btn-nav-register { width: 100%; text-align: center; display: block; padding: 0.6rem; }
        }

        /* ============ CARDS ============ */
        .dest-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border) !important;
            border-radius: 14px !important;
            overflow: hidden;
            transition: transform .2s, box-shadow .2s;
        }

        .dest-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(30,77,140,0.18) !important;
        }

        .dest-card img { height: 200px; object-fit: cover; }

        .dest-card .card-body {
            background: var(--card-bg);
        }

        /* ============ FOOTER ============ */
        .routeora-footer {
            background: var(--blue-5);
            color: rgba(200,225,255,0.75);
            padding: 3rem 0 1.5rem;
            margin-top: 5rem;
        }

        .routeora-footer h6 {
            color: #fff;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            letter-spacing: 0.3px;
            margin-bottom: 0.75rem;
        }

        .routeora-footer a {
            color: rgba(168,237,234,0.75);
            text-decoration: none;
            font-size: 0.875rem;
            line-height: 2;
            transition: color 0.2s;
        }

        .routeora-footer a:hover { color: #a8edea; }

        .footer-brand {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 1.3rem;
            background: linear-gradient(90deg, #fff, #a8edea, #00E5C8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .footer-divider {
            border-color: rgba(0,229,200,0.12);
            margin: 2rem 0 1rem;
        }

        .footer-copy {
            color: rgba(200,225,255,0.3);
            font-size: 0.8rem;
            text-align: center;
        }

        /* ============ HERO ============ */
    .hero-section {
    min-height: 520px;
    background-image: url('/images/hero/home_page_main_photo.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: #fff;
    display: flex;
    align-items: center;
    position: relative;
}

.hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
}

.hero-section .container {
    position: relative;
    z-index: 2;
}

.dest-card img {
    height: 220px;
    object-fit: cover;
}

        /* ============ GENERAL ============ */
        .btn-primary {
            background: linear-gradient(135deg, var(--blue-4), var(--blue-3));
            border: none;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, var(--blue-3), var(--blue-4));
            transform: translateY(-1px);
        }

        .badge.bg-primary-subtle { background: rgba(74,126,194,0.15) !important; color: var(--blue-4) !important; }
    </style>
</head>
<body>

<!-- ============ NAVBAR ============ -->
<nav class="routeora-nav">
    <div class="nav-inner">
        <a class="brand-logo" asp-controller="Home" asp-action="Index">
            <span class="brand-icon"><i class="bi bi-compass-fill"></i></span>
            Routeora
        </a>

        <button class="nav-toggle" id="navToggle">
            <i class="bi bi-list" style="font-size:1.2rem;"></i>
        </button>

        <div class="nav-collapsible" id="navCollapsible">
            <ul class="nav-links">
                <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-house"></i> Home</a></li>
                <li><a asp-controller="Destination" asp-action="Index"><i class="bi bi-compass"></i> Destinations</a></li>
                <li><a asp-controller="Destination" asp-action="VisaFree"><i class="bi bi-passport"></i> Visa-Free</a></li>
                <li><a asp-controller="Destination" asp-action="SuggestedRoutes"><i class="bi bi-map"></i> Routes</a></li>
                <li><a asp-controller="Home" asp-action="TravelTips"><i class="bi bi-lightbulb"></i> Tips</a></li>
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <li><a asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart"></i> Wishlist</a></li>
                    <li><a asp-controller="Trip" asp-action="Index"><i class="bi bi-suitcase"></i> My Trips</a></li>
                }
            </ul>

            <div class="nav-auth">
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <span class="nav-user-greeting">Hi, @Context.Session.GetString("UserName")!</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-nav-logout">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn-nav-login" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn-nav-register" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </div>
    </div>
</nav>

<main>
    @RenderBody()
</main>

<!-- ============ FOOTER ============ -->
<footer class="routeora-footer">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4 mb-2">
                <div class="footer-brand mb-2"><i class="bi bi-compass-fill me-2"></i>Routeora</div>
                <p class="small" style="color:rgba(200,225,255,0.5);line-height:1.7;">Discover the world, plan your next adventure. Your journey starts here.</p>
            </div>
            <div class="col-lg-2 col-sm-4">
                <h6>Explore</h6>
                <ul class="list-unstyled">
                    <li><a asp-controller="Destination" asp-action="Index">Destinations</a></li>
                    <li><a asp-controller="Destination" asp-action="VisaFree">Visa-Free</a></li>
                    <li><a asp-controller="Destination" asp-action="SuggestedRoutes">Routes</a></li>
                    <li><a asp-controller="Home" asp-action="TravelTips">Travel Tips</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-sm-4">
                <h6>Account</h6>
                <ul class="list-unstyled">
                    <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                    <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li><a asp-controller="Wishlist" asp-action="Index">Wishlist</a></li>
                        <li><a asp-controller="Trip" asp-action="Index">My Trips</a></li>
                    }
                </ul>
            </div>
            <div class="col-lg-4 col-sm-4">
                <h6>Destinations</h6>
                <ul class="list-unstyled">
                    <li><a asp-controller="Destination" asp-action="Index">Italy · Spain · Japan</a></li>
                    <li><a asp-controller="Destination" asp-action="Index">Korea · Thailand · Turkey</a></li>
                    <li><a asp-controller="Destination" asp-action="Index">Russia · Switzerland</a></li>
                </ul>
            </div>
        </div>
        <hr class="footer-divider" />
        <p class="footer-copy mb-0">&copy; 2026 Routeora. All rights reserved.</p>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Mobile nav toggle
    const navToggle = document.getElementById('navToggle');
    const navCol = document.getElementById('navCollapsible');
    if (navToggle) {
        navToggle.addEventListener('click', () => navCol.classList.toggle('open'));
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
