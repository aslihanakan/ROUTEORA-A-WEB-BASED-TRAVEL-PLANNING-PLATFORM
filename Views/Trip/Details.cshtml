@model TravelPlanner.Models.Trip
@{
    ViewData["Title"] = "Trip Details";
    var days = (Model.EndDate - Model.StartDate).Days;
    var destLabel = Model.Destination == null
        ? $"#{Model.DestinationId}"
        : string.IsNullOrWhiteSpace(Model.Destination.CityName)
            ? Model.Destination.CountryName
            : $"{Model.Destination.CityName}, {Model.Destination.CountryName}";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <h2 class="fw-bold mb-0">Trip Details</h2>
                        <span class="badge bg-primary fs-6">@days days</span>
                    </div>
                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item px-0"><strong>Destination:</strong> @destLabel</li>
                        <li class="list-group-item px-0"><strong>Start Date:</strong> @Model.StartDate.ToString("MMMM d, yyyy")</li>
                        <li class="list-group-item px-0"><strong>End Date:</strong> @Model.EndDate.ToString("MMMM d, yyyy")</li>
                        <li class="list-group-item px-0"><strong>Budget:</strong> $@Model.Budget</li>
                        <li class="list-group-item px-0"><strong>Travel Style:</strong> @(Model.TravelStyle ?? "—")</li>
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <li class="list-group-item px-0"><strong>Notes:</strong> @Model.Notes</li>
                        }
                    </ul>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary flex-grow-1">Edit</a>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">Back to Trips</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
