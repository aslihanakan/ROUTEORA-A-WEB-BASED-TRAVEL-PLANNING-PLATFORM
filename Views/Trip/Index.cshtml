@model IEnumerable<TravelPlanner.Models.Trip>

@{
    ViewData["Title"] = "My Trips";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0">
                <i class="bi bi-suitcase me-2 text-primary"></i>My Trips
            </h1>
            <p class="text-muted mb-0">Your travel plans</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Trip
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-suitcase text-muted" style="font-size:4rem;"></i>
            <h4 class="mt-3 text-muted">No trips planned yet</h4>
            <a asp-action="Create" class="btn btn-primary mt-2">Plan Your First Trip</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var t in Model)
            {
                var days = 0;

                if (t.StartDate.Year > 1 && t.EndDate.Year > 1)
                {
                    days = (t.EndDate - t.StartDate).Days;
                }

                var tripTitle = "Unknown Destination";

                if (!string.IsNullOrWhiteSpace(t.RouteName))
                {
                    tripTitle = t.RouteName;
                }
                else if (t.Destination != null)
                {
                    if (!string.IsNullOrWhiteSpace(t.Destination.CityName) &&
                        !string.IsNullOrWhiteSpace(t.Destination.CountryName))
                    {
                        tripTitle = $"{t.Destination.CityName}, {t.Destination.CountryName}";
                    }
                    else if (!string.IsNullOrWhiteSpace(t.Destination.CountryName))
                    {
                        tripTitle = t.Destination.CountryName;
                    }
                    else if (!string.IsNullOrWhiteSpace(t.Destination.CityName))
                    {
                        tripTitle = t.Destination.CityName;
                    }
                }

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-primary-subtle text-primary">
                                    @(t.TravelStyle ?? "General")
                                </span>

                                <span class="small text-muted">
                                    @(days > 0 ? $"{days} days" : "Date not set")
                                </span>
                            </div>

                            <h5 class="fw-bold">@tripTitle</h5>

                            <ul class="list-unstyled small text-muted mb-3">
                                <li>
                                    <i class="bi bi-calendar me-2"></i>

                                    @if (t.StartDate.Year > 1 && t.EndDate.Year > 1)
                                    {
                                        @($"{t.StartDate:MMM d} – {t.EndDate:MMM d, yyyy}")
                                    }
                                    else
                                    {
                                        <span>Date not selected</span>
                                    }
                                </li>

                                <li>
                                    <i class="bi bi-currency-dollar me-2"></i>

                                    @if (t.Budget > 0)
                                    {
                                        <span>Budget: $@t.Budget</span>
                                    }
                                    else
                                    {
                                        <span>Budget not set</span>
                                    }
                                </li>

                                @if (!string.IsNullOrWhiteSpace(t.Notes))
                                {
                                    <li class="mt-1">
                                        <i class="bi bi-journal me-2"></i>@t.Notes
                                    </li>
                                }
                            </ul>

                            <div class="d-flex gap-2">
                                <a asp-action="Details"
                                   asp-route-id="@t.Id"
                                   class="btn btn-outline-primary btn-sm flex-grow-1">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@t.Id"
                                   class="btn btn-outline-secondary btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@t.Id"
                                   class="btn btn-outline-danger btn-sm">
                                    Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>