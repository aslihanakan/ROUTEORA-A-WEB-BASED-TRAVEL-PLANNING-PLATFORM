@model TravelPlanner.Models.Trip
@using Microsoft.AspNetCore.Mvc.Rendering
@inject TravelPlanner.Data.AppDbContext Db
@{
    ViewData["Title"] = "Plan a Trip";
    var destinations = Db.Destinations.OrderBy(d => d.CountryName).ToList();
    var selectedId = Model.DestinationId;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-1"><i class="bi bi-suitcase me-2 text-primary"></i>Plan a New Trip</h2>
                    <p class="text-muted mb-4">Fill in the details for your adventure</p>
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                     @if (!string.IsNullOrWhiteSpace(Model.RouteName))
{
    <input asp-for="RouteName" type="hidden" />

    <div class="mb-3">
        <label class="form-label fw-semibold">Selected Route</label>

        <div class="alert alert-primary mb-0">
            <i class="bi bi-map me-2"></i>@Model.RouteName
        </div>
    </div>
}
else if (Model.DestinationId > 0)
{
    <input type="hidden" name="DestinationId" value="@Model.DestinationId" />

    var selectedDestination = destinations.FirstOrDefault(x => x.Id == Model.DestinationId);

    <div class="mb-3">
        <label class="form-label fw-semibold">Destination</label>
        <div class="alert alert-info mb-0">
            @(selectedDestination == null
                ? "Destination selected"
                : string.IsNullOrWhiteSpace(selectedDestination.CityName)
                    ? selectedDestination.CountryName
                    : $"{selectedDestination.CityName}, {selectedDestination.CountryName}")
        </div>
    </div>
}
else
{
    <div class="mb-3">
        <label class="form-label fw-semibold">Destination</label>

        <select name="DestinationId" class="form-select" required>
            <option value="">— Select a destination —</option>

            @foreach (var d in destinations)
            {
                var label = string.IsNullOrWhiteSpace(d.CityName)
                    ? d.CountryName
                    : $"{d.CityName}, {d.CountryName}";

                <option value="@d.Id">@label</option>
            }
        </select>
    </div>
}
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label asp-for="StartDate" class="form-label fw-semibold">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="EndDate" class="form-label fw-semibold">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Budget" class="form-label fw-semibold">Budget ($)</label>
                            <input asp-for="Budget" type="number" class="form-control" placeholder="e.g. 1500" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="TravelStyle" class="form-label fw-semibold">Travel Style</label>
                            <select asp-for="TravelStyle" class="form-select">
                                <option value="">— Select style —</option>
                                <option>Backpacker</option>
                                <option>Budget</option>
                                <option>Mid-range</option>
                                <option>Luxury</option>
                                <option>Adventure</option>
                                <option>Cultural</option>
                                <option>Beach</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any special plans or reminders..."></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1 py-2">
                                <i class="bi bi-check-lg me-1"></i>Save Trip
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
