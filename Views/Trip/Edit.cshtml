@model TravelPlanner.Models.Trip
@inject TravelPlanner.Data.AppDbContext Db
@{
    ViewData["Title"] = "Edit Trip";
    var destinations = Db.Destinations.OrderBy(d => d.CountryName).ToList();
    var styles = new[] { "Backpacker", "Budget", "Mid-range", "Luxury", "Adventure", "Cultural", "Beach" };
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-1"><i class="bi bi-pencil me-2 text-primary"></i>Edit Trip</h2>
                    <p class="text-muted mb-4">Update your trip details</p>
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Destination</label>
                            <select name="DestinationId" class="form-select" required>
                                <option value="">— Select a destination —</option>
                                @foreach (var d in destinations)
                                {
                                    var label = string.IsNullOrWhiteSpace(d.CityName)
                                        ? d.CountryName
                                        : $"{d.CityName}, {d.CountryName}";

                                    if (d.Id == Model.DestinationId)
                                    {
                                        <option value="@d.Id" selected>@label</option>
                                    }
                                    else
                                    {
                                        <option value="@d.Id">@label</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label asp-for="StartDate" class="form-label fw-semibold">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="EndDate" class="form-label fw-semibold">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Budget" class="form-label fw-semibold">Budget ($)</label>
                            <input asp-for="Budget" type="number" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="TravelStyle" class="form-label fw-semibold">Travel Style</label>
                            <select name="TravelStyle" class="form-select">
                                <option value="">— Select style —</option>
                                @foreach (var s in styles)
                                {
                                    if (s == Model.TravelStyle)
                                    {
                                        <option selected>@s</option>
                                    }
                                    else
                                    {
                                        <option>@s</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1 py-2">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
