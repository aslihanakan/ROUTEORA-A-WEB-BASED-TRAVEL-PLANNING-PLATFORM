<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">
            <i class="bi bi-map me-2 text-primary"></i>Suggested Routes ⭐
        </h1>
        <p class="text-muted lead">
            Ready-made multi-country itineraries for every travel style
        </p>
    </div>

    @* ── Filter bar ── *@
    <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
        <button class="btn btn-sm btn-outline-secondary filter-btn active" data-filter="all">All Routes</button>
        <button class="btn btn-sm btn-outline-success filter-btn" data-filter="Budget">
            <i class="bi bi-piggy-bank me-1"></i>Budget
        </button>
        <button class="btn btn-sm btn-outline-primary filter-btn" data-filter="Comfort">
            <i class="bi bi-stars me-1"></i>Comfort
        </button>
    </div>

    <div class="row g-4" id="routeGrid">

        @for (int ri = 0; ri < allRoutes.Count; ri++)
        {
            var r          = allRoutes[ri];
            var collapseId = "routeDetails" + ri;

            <div class="col-lg-6 route-item" data-budget="@r.BudgetLevel">
                <div class="card h-100 border-0 shadow-sm route-card">

                    <div class="route-card-stripe @(r.BudgetLevel == "Budget" ? "stripe-budget" : "stripe-comfort")"></div>

                    <div class="card-body p-4">

                        @* Title row *@
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="route-icon-wrap @(r.BudgetLevel == "Budget" ? "icon-budget" : "icon-comfort")">
                                    <i class="bi @GetRouteIcon(r.RouteName)"></i>
                                </span>
                                <h5 class="fw-bold mb-0">@r.RouteName</h5>
                            </div>
                            <span class="badge @(r.BudgetLevel == "Budget" ? "bg-success" : "bg-primary")">
                                @r.BudgetLevel
                            </span>
                        </div>

                        <p class="text-primary fw-semibold mb-2 small">
                            <i class="bi bi-arrow-right-circle me-1"></i>@r.Countries
                        </p>

                        <p class="text-muted small mb-3">@r.Description</p>

                        @* Meta row *@
                        <div class="d-flex gap-3 text-muted small mb-2 flex-wrap">
                            <span><i class="bi bi-clock me-1"></i>@r.Duration</span>
                            <span><i class="bi bi-calendar3 me-1"></i>@r.BestTime</span>
                        </div>

                        @* Cost badge *@
                        <div class="mb-3">
                            <span class="cost-badge">
                                <i class="bi bi-wallet2 me-1"></i>@r.EstimatedCost
                            </span>
                        </div>

                        @* Action buttons *@
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary btn-sm flex-fill"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="false">
                                <i class="bi bi-info-circle me-1"></i>Details
                            </button>

                            <form asp-controller="Wishlist" asp-action="AddRoute" method="post" class="flex-fill">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="routeName" value="@r.RouteName" />
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                    <i class="bi bi-heart-fill me-1"></i>Favourite
                                </button>
                            </form>

                            <form asp-controller="Trip" asp-action="CreateFromRoute" method="post" class="flex-fill">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="routeName" value="@r.RouteName" />
                                <button type="submit" class="btn btn-primary btn-sm w-100">
                                    <i class="bi bi-suitcase-lg-fill me-1"></i>Plan Trip
                                </button>
                            </form>
                        </div>

                        @* Collapsible detail panel *@
                        <div class="collapse mt-4" id="@collapseId">
                            <div class="route-detail-box">

                                <h6 class="fw-bold mb-3">
                                    <i class="bi bi-calendar-check me-1 text-primary"></i>Suggested Itinerary
                                </h6>

                                <div class="timeline mb-4">
                                    @for (int si = 0; si < r.Stops.Length; si++)
                                    {
                                        var stop   = r.Stops[si];
                                        var isLast = si == r.Stops.Length - 1;
                                        <div class="timeline-item @(isLast ? "timeline-item-last" : "")">
                                            <div class="timeline-dot">@(si + 1)</div>
                                            <div class="timeline-content">
                                                <div class="fw-semibold small">
                                                    @stop.City
                                                    <span class="badge bg-light text-secondary border ms-1">@stop.Days</span>
                                                </div>
                                                <div class="text-muted" style="font-size:.80rem;margin-top:3px;">@stop.Highlights2</div>
                                                <div class="tip-box mt-2">
                                                    <i class="bi bi-lightbulb-fill text-warning me-1"></i>
                                                    <span style="font-size:.78rem;">@stop.Tips</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <h6 class="fw-bold mb-2">
                                    <i class="bi bi-wallet2 me-1 text-success"></i>Estimated Cost
                                </h6>
                                <p class="small text-muted mb-1">@r.EstimatedCost</p>
                                <p class="small text-muted mb-3">@GetBudgetText(r.BudgetLevel)</p>

                                <h6 class="fw-bold mb-2">
                                    <i class="bi bi-train-front me-1 text-info"></i>Getting Around
                                </h6>
                                <p class="small text-muted mb-3">@r.Transport</p>

                                <h6 class="fw-bold mb-2">
                                    <i class="bi bi-star-fill me-1 text-warning"></i>Must-See Highlights
                                </h6>
                                <div class="d-flex flex-wrap gap-1 mb-0">
                                    @foreach (var hl in r.Highlights.Split(","))
                                    {
                                        <span class="badge rounded-pill bg-light text-secondary border">@hl.Trim()</span>
                                    }
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>
</div>

<style>
    .route-card {
        border-radius: 18px;
        transition: transform .25s, box-shadow .25s;
        overflow: hidden;
    }
    .route-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(0,0,0,.12) !important;
    }
    .route-card-stripe { height: 5px; }
    .stripe-budget  { background: linear-gradient(90deg,#198754,#20c997); }
    .stripe-comfort { background: linear-gradient(90deg,#0d6efd,#6610f2); }

    .route-icon-wrap {
        width: 34px; height: 34px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; flex-shrink: 0;
    }
    .icon-budget  { background:rgba(25,135,84,.12);  color:#198754; }
    .icon-comfort { background:rgba(13,110,253,.12); color:#0d6efd; }

    .cost-badge {
        display: inline-block;
        background: #f0f9f4;
        color: #146c43;
        border: 1px solid #a3d9b7;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: .78rem;
        font-weight: 600;
    }

    /* Timeline */
    .timeline { position: relative; padding-left: 0; }
    .timeline-item {
        display: flex; gap: 14px; position: relative; padding-bottom: 16px;
    }
    .timeline-item::before {
        content:''; position:absolute; left:15px; top:28px; bottom:0;
        width:2px; background:#dee2e6;
    }
    .timeline-item-last::before { display:none; }
    .timeline-dot {
        width:32px; height:32px; border-radius:50%;
        background:#0d6efd; color:#fff;
        font-size:.75rem; font-weight:700;
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0; position:relative; z-index:1;
    }
    .timeline-content { flex:1; padding-top:5px; }
    .tip-box {
        background:#fffbea; border-left:3px solid #ffc107;
        border-radius:0 6px 6px 0; padding:5px 8px;
    }

    .route-detail-box {
        background:#f6f9ff;
        border:1px solid rgba(13,110,253,.15);
        border-radius:16px; padding:20px;
    }
    .route-card .btn { border-radius:10px; font-weight:600; }

    .filter-btn.active { background-color:#0d6efd; color:#fff; border-color:#0d6efd; }
</style>

<script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const filter = this.dataset.filter;
            document.querySelectorAll('.route-item').forEach(card => {
                card.style.display = (filter === 'all' || card.dataset.budget === filter) ? '' : 'none';
            });
        });
    });
</script>
