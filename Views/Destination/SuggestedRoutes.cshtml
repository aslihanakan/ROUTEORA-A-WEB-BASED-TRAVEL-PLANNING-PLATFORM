@model IEnumerable<TravelPlanner.Models.SuggestedRoute>

@{
    ViewData["Title"] = "Suggested Routes";
}

@functions {
    string GetBudgetText(string budgetLevel)
    {
        if (budgetLevel == "Budget")
            return "Prefer hostels, public transport, local restaurants and early flight bookings to keep costs down.";
        return "Central hotels, faster transfers and more flexible daily activities fit this budget comfortably.";
    }

    string GetRouteIcon(string routeName)
    {
        if (routeName.Contains("Balkan"))       return "bi-globe-europe-africa";
        if (routeName.Contains("Scandinavia"))  return "bi-snow";
        if (routeName.Contains("Mediterranean"))return "bi-sun";
        if (routeName.Contains("Eastern"))      return "bi-building";
        if (routeName.Contains("Iberian"))      return "bi-brightness-high";
        if (routeName.Contains("British"))      return "bi-umbrella";
        if (routeName.Contains("Alpine"))       return "bi-triangle";
        if (routeName.Contains("Baltic"))       return "bi-water";
        if (routeName.Contains("French"))       return "bi-balloon-heart";
        if (routeName.Contains("Adriatic"))     return "bi-tsunami";
        if (routeName.Contains("Black Sea"))    return "bi-compass";
        return "bi-compass";
    }
}

@{
    /* ─── Stop record ─── */
    var allRoutes = new List<(
        string RouteName, string Countries, string Duration, string BudgetLevel,
        string Description, string BestTime, string Transport, string Highlights,
        string EstimatedCost,
        (string City, string Days, string Highlights2, string Tips)[] Stops
    )>
    {
        /* ══ BUDGET ══════════════════════════════════════════════════════════════ */
        (
            "Balkan Explorer",
            "Serbia → Bosnia → Croatia → Slovenia",
            "14 days", "Budget",
            "Hidden gems of the Balkans — from Belgrade's nightlife to Dubrovnik's old-city walls.",
            "May – September",
            "FlixBus / BlaBlaCar between cities; local trams & buses within cities.",
            "UNESCO old towns, Adriatic coast, stunning lakes, affordable food & accommodation",
            "~€600–900 per person (incl. transport, accommodation & food)",
            new[]{
                ("Belgrade, Serbia",    "3 days", "Kalemegdan Fortress, Skadarlija bohemian quarter, Savamala district. Try ćevapi and rakija.", "Use BlaBlaCar or FlixBus between cities — very cheap."),
                ("Sarajevo, Bosnia",    "3 days", "Baščaršija bazaar, Latin Bridge, War Tunnel Museum. Don't miss Bosnian coffee.",               "Book accommodation near the old town for easy walking access."),
                ("Split, Croatia",      "3 days", "Diocletian's Palace (UNESCO), Marjan Hill sunset, ferry to Hvar island.",                       "Visit Plitvice Lakes on a day trip — book tickets online in advance."),
                ("Ljubljana, Slovenia", "2 days", "Ljubljana Castle, Tivoli Park, Triple Bridge. Day trip to Lake Bled.",                           "Rent a bike — the city is compact and very cycling-friendly."),
            }
        ),
        (
            "Eastern Europe Circuit",
            "Poland → Czech Republic → Hungary → Romania",
            "16 days", "Budget",
            "Gothic spires, thermal baths, dark history and some of Europe's most underrated cities.",
            "April–May or September–October",
            "RegioJet or FlixBus trains/coaches between cities — comfortable and very affordable.",
            "Medieval architecture, thermal baths, excellent food value, rich WWII history",
            "~€700–1000 per person (incl. transport, accommodation & food)",
            new[]{
                ("Kraków, Poland",              "3 days", "Wawel Castle, Kazimierz Jewish quarter, Wieliczka Salt Mine, Auschwitz memorial.",    "Auschwitz visit is emotionally significant — book a guided tour in advance."),
                ("Prague, Czech Republic",      "4 days", "Charles Bridge at dawn, Prague Castle, Old Town Square & Astronomical Clock.",        "Climb the castle steps at sunrise — no crowds and an extraordinary view."),
                ("Budapest, Hungary",           "4 days", "Széchenyi Thermal Baths, Fisherman's Bastion, ruin bars, Danube cruise.",            "Ruin bars are unique to Budapest — Szimpla Kert is the original and best."),
                ("Bucharest & Brașov, Romania", "3 days", "Palace of Parliament, Old Town Lipscani, Bran Castle, Sinaia mountain resort.",      "Take the train Bucharest–Brașov for €8 and explore Transylvania affordably."),
            }
        ),
        (
            "Baltic Sea Loop",
            "Estonia → Latvia → Lithuania → Poland",
            "12 days", "Budget",
            "Medieval old towns, Soviet history, amber beaches and Europe's least-visited gems.",
            "May – August",
            "Lux Express coach between all four cities — comfortable, Wi-Fi, very affordable.",
