<!-- Hero image -->
@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div style="height:420px;overflow:hidden;position:relative;">
        <img src="@Model.ImageUrl" class="w-100 h-100" style="object-fit:cover;object-position:center;" alt="@Model.CityName" />
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(10,31,78,0.85));display:flex;align-items:flex-end;">
            <div class="container pb-4">
                <h1 class="display-4 fw-bold text-white mb-1">@Model.CityName</h1>
                <p class="text-white-50 mb-0"><i class="bi bi-geo-alt me-1"></i>@Model.CountryName &nbsp;·&nbsp;
                   <i class="bi bi-sun me-1"></i>Best season: @Model.BestSeason &nbsp;·&nbsp;
                   <i class="bi bi-wallet2 me-1"></i>From $@Model.EstimatedBudget</p>
            </div>
        </div>
    </div>
}

<div class="container py-5">
    <div class="row g-4">

        <!-- LEFT: description + attractions + activities -->
        <div class="col-lg-8">

            <!-- Description -->
            <div class="card dest-card mb-4 p-4">
                <h5 class="fw-bold mb-2"><i class="bi bi-info-circle me-2 text-primary"></i>About @Model.CityName</h5>
                <p class="mb-0">@Model.Description</p>
            </div>

            <!-- Top Attractions -->
            <div class="card dest-card mb-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-camera me-2 text-primary"></i>Top Attractions</h5>
                <div class="row g-2">
                    @foreach (var a in attractions)
                    {
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-2 p-2 rounded" style="background:rgba(74,126,194,0.07);">
                                <i class="bi bi-star-fill text-warning" style="font-size:.75rem;"></i>
                                <span class="small fw-medium">@a</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Recommended Activities -->
            <div class="card dest-card mb-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-lightning me-2 text-primary"></i>Recommended Activities</h5>
                <ul class="list-unstyled mb-0">
                    @foreach (var act in activities)
                    {
                        <li class="d-flex align-items-start gap-2 mb-2">
                            <i class="bi bi-check2-circle text-success mt-1" style="font-size:.9rem;"></i>
                            <span class="small">@act</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- RIGHT: budget + quick info + wishlist -->
        <div class="col-lg-4">

            <!-- Budget Breakdown -->
            <div class="card dest-card mb-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-wallet2 me-2 text-primary"></i>Budget Guide</h5>
                <div class="mb-3">
                    <p class="small fw-semibold text-muted mb-1 text-uppercase" style="font-size:.7rem;letter-spacing:.5px;">Accommodation</p>
                    <p class="small mb-0">@accommodation</p>
                </div>
                <hr class="my-2" style="border-color:var(--card-border);" />
                <div class="mb-3">
                    <p class="small fw-semibold text-muted mb-1 text-uppercase" style="font-size:.7rem;letter-spacing:.5px;">Food & Drink</p>
                    <p class="small mb-0">@food</p>
                </div>
                <hr class="my-2" style="border-color:var(--card-border);" />
                <div class="mb-3">
                    <p class="small fw-semibold text-muted mb-1 text-uppercase" style="font-size:.7rem;letter-spacing:.5px;">Transport</p>
                    <p class="small mb-0">@transport</p>
                </div>
                <hr class="my-2" style="border-color:var(--card-border);" />
                <div class="p-3 rounded text-center" style="background:linear-gradient(135deg,var(--blue-4),var(--blue-3));color:#fff;">
                    <div class="fw-bold" style="font-size:1.1rem;">@dailyBudget</div>
                    <div class="small opacity-75">estimated daily spend</div>
                    <hr style="border-color:rgba(255,255,255,0.2);margin:.75rem 0;" />
                    <div class="fw-semibold small">@totalAvg</div>
                </div>
            </div>

            <!-- Quick Info -->
            <div class="card dest-card mb-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>Quick Info</h5>
                <div class="d-flex justify-content-between small border-bottom py-2">
                    <span class="text-muted">Country</span>
                    <span class="fw-semibold">@Model.CountryName</span>
                </div>
                <div class="d-flex justify-content-between small border-bottom py-2">
                    <span class="text-muted">Best Season</span>
                    <span class="fw-semibold">@Model.BestSeason</span>
                </div>
                <div class="d-flex justify-content-between small py-2">
                    <span class="text-muted">Est. Budget</span>
                    <span class="fw-semibold text-success">from $@Model.EstimatedBudget</span>
                </div>
            </div>

            <!-- Wishlist / Action buttons -->
            @if (loggedIn)
            {
                <form asp-controller="Wishlist" asp-action="Add" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="destinationId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-heart me-2"></i>Add to Wishlist
                    </button>
                </form>
               <a asp-controller="Trip"
   asp-action="Create"
   asp-route-destinationId="@Model.Id"
   class="btn btn-primary w-100 mb-3">
    <i class="bi bi-suitcase me-2"></i>Plan a Trip Here
</a>
            }
            else
            {
                <div class="card dest-card p-3 text-center mb-3">
                    <p class="small text-muted mb-2">Sign in to save this destination</p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm w-100 mb-2">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-sm w-100">Register</a>
                </div>
            }

            <a asp-controller="Destination" asp-action="Index" class="btn btn-outline-secondary w-100">
                <i class="bi bi-arrow-left me-2"></i>Back to Destinations
            </a>
        </div>
    </div>
</div>
