@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="hero-section">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold mb-3">
                    Your Next Adventure<br />Starts Here
                </h1>

                <p class="lead opacity-90 mb-4">
                    Discover visa-free destinations, plan your trips and find the perfect route — all in one place.
                </p>

                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Destination" asp-action="Index" class="btn btn-light btn-lg px-4">
                        <i class="bi bi-compass me-2"></i>Explore Destinations
                    </a>
                </div>
            </div>

            <div class="col-lg-5"></div>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="py-4 bg-body-secondary">
    <div class="container">
        <div class="row text-center g-3">
    <div class="col-4">
        <div class="fw-bold fs-3 text-primary">
            @ViewBag.DestinationCount+
        </div>
        <div class="small text-muted">Destinations</div>
    </div>

    <div class="col-4">
        <div class="fw-bold fs-3 text-primary">
            @ViewBag.VisaFreeCount+
        </div>
        <div class="small text-muted">Visa-Free Countries</div>
    </div>

    <div class="col-4">
        <div class="fw-bold fs-3 text-primary">
            @ViewBag.RouteCount
        </div>
        <div class="small text-muted">Suggested Routes</div>
    </div>
</div>
        </div>
    </div>
</section>

<!-- ABOUT ROUTEORA -->
<section class="py-5 about-routeora-section">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h2 class="fw-bold mb-3">Plan Your Journey Easily with Routeora</h2>

                <p class="text-muted fs-5 mb-3">
                    Routeora helps travelers discover beautiful destinations, compare travel budgets,
                    explore visa-free options and find suggested routes in one simple platform.
                </p>

                <p class="text-muted mb-0">
                    Instead of searching across many different websites, users can quickly view countries,
                    cities, seasons, estimated budgets and route ideas from one clean and easy-to-use travel guide.
                </p>
            </div>

            <div class="col-lg-5">
                <div class="about-card shadow-sm">
                    <div class="about-icon">🌍</div>
                    <h5 class="fw-bold mb-2">Smart Travel Planning</h5>
                    <p class="text-muted mb-0">
                        Discover destinations, check details and start planning your next adventure faster.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURED DESTINATIONS -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Featured Destinations</h2>

            <a asp-controller="Destination" asp-action="Index" class="btn btn-outline-primary btn-sm">
                View All →
            </a>
        </div>

        <div class="row g-4">
            @{
                var featured = new[]
                {
                    new { Id = 1, City = "Tokyo", Country = "Japan", Img = "/images/destinations/Japan/Tokyo.jpg", Season = "Spring", Budget = 1800 },
                    new { Id = 4, City = "Rome", Country = "Italy", Img = "/images/destinations/Italy/Rome.jpg", Season = "Autumn", Budget = 1400 },
                    new { Id = 7, City = "Barcelona", Country = "Spain", Img = "/images/destinations/Spain/Barcelona.jpg", Season = "Summer", Budget = 1300 }
                };
            }

            @foreach (var d in featured)
            {
                <div class="col-md-4">
                    <div class="card dest-card h-100 shadow-sm border-0">
                        <img src="@d.Img" class="card-img-top" alt="@d.City" loading="lazy" />

                        <div class="card-body">
                            <h5 class="card-title fw-bold">@d.City</h5>

                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt me-1"></i>@d.Country
                            </p>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary-subtle text-primary badge-season">
                                    <i class="bi bi-sun me-1"></i>@d.Season
                                </span>

                                <span class="fw-semibold text-success">from $@d.Budget</span>
                            </div>

                            <a asp-controller="Destination"
                               asp-action="Details"
                               asp-route-id="@d.Id"
                               class="btn btn-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .about-routeora-section {
        background: linear-gradient(180deg, #f4f8ff 0%, #ffffff 100%);
    }

    .about-card {
        background: #ffffff;
        border-radius: 22px;
        padding: 35px;
        text-align: center;
    }

    .about-icon {
        font-size: 3rem;
        margin-bottom: 15px;
    }

    .dest-card {
        border-radius: 18px;
        overflow: hidden;
    }

    .dest-card img {
        height: 220px;
        width: 100%;
        object-fit: cover;
    }
</style>