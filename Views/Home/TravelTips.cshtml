@{
    ViewData["Title"] = "Travel Tips";
}

<!-- Hero -->
<div class="bg-primary text-white py-5">
    <div class="container text-center">
        <h1 class="fw-bold display-5">
            <i class="bi bi-lightbulb me-2"></i>Travel Guide
        </h1>
        <p class="lead opacity-90">
            Essential information before travelling abroad
        </p>
    </div>
</div>

<div class="container py-5">

    <div class="row g-4">

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        🛂 Passport Requirements
                    </h4>

                    <p class="text-muted mb-0">
                        Most countries require your passport to be valid for at least
                        6 months after your travel date. Always check passport validity before booking.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        📄 Visa Requirements
                    </h4>

                    <p class="text-muted mb-0">
                        Before travelling, verify whether the destination requires
                        a visa, e-visa, visa on arrival or allows visa-free entry.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        🏨 Hotel Reservation
                    </h4>

                    <p class="text-muted mb-0">
                        Immigration officers may ask for hotel reservations,
                        invitation letters or accommodation information.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        🎫 Return Ticket
                    </h4>

                    <p class="text-muted mb-0">
                        Many countries require proof that you will leave
                        before your permitted stay expires.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        💳 Financial Proof
                    </h4>

                    <p class="text-muted mb-0">
                        You may need to prove you have sufficient funds
                        for accommodation, food and transportation.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        🏥 Travel Insurance
                    </h4>

                    <p class="text-muted mb-0">
                        Travel health insurance is highly recommended and
                        sometimes mandatory depending on the destination.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        💉 Vaccination Requirements
                    </h4>

                    <p class="text-muted mb-0">
                        Some countries require vaccination certificates or
                        health declarations before arrival.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold">
                        ⚠️ Official Sources
                    </h4>

                    <p class="text-muted mb-0">
                        Always check the latest travel regulations through
                        official government and embassy websites before departure.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="alert alert-warning mt-5 shadow-sm">
        <h5 class="fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Important Notice
        </h5>

        <p class="mb-0">
            Visa-free travel does not guarantee entry. Border authorities may request
            additional documents such as hotel reservations, return tickets, proof of
            funds, travel insurance or completed entry forms.
        </p>
    </div>

</div>